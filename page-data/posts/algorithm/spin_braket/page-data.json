\n\t\t}\n\t\ti++;\n\t}\n\treturn stack.length === 0;\n}\n\nfunction solution(s) {\n\tlet answer = 0;\n\n\tlet i = 0;\n\twhile (i < s.length) {\n\t\t// 한칸씩 밀어준다.\n\t\tconst newStr = s.split(\"\").reduce((acc, _, index, arr) => acc + arr[(index + i) % s.length], '')\n\t\tif (isValid(newStr)) {\n\t\t\tanswer++;\n\t\t}\n\t\ti++;\n\t}\n\n\treturn answer;\n}\n"}]},{"type":"text","value":"\n        "}]}],"data":{"quirksMode":false}},"excerpt":"…","fields":{"readingTime":{"text":"2 min read"},"slug":"/posts/algorithm/spin_braket/","series":""},"frontmatter":{"series":null,"title":"[프로그래머스 월간 코드챌린지2] - 괄호 회전하기","userDate":"20 April 2021","date":"2021-04-20T00:00:00.000Z","tags":["algorithm"],"excerpt":null,"image":null,"author":[{"id":"padawanr0k","bio":"The professional publishing platform","avatar":{"children":[{"fluid":{"base64":"data:image/png;base64,","aspectRatio":1,"src":"/static/28754d21e9a871bc77494c67330cad10/bc8e0/youtube_profile_image.png","srcSet":"/static/28754d21e9a871bc77494c67330cad10/22f7f/youtube_profile_image.png 40w,\n/static/28754d21e9a871bc77494c67330cad10/587c9/youtube_profile_image.png 80w,\n/static/28754d21e9a871bc77494c67330cad10/d966b/youtube_profile_image.png 120w,\n/static/28754d21e9a871bc77494c67330cad10/bc8e0/youtube_profile_image.png 800w","sizes":"(max-width: 800px) 100vw, 800px"}}]}}]},"tableOfContents":"<ul>\n<li>\n<p><a href=\"#%EA%B4%84%ED%98%B8-%ED%9A%8C%EC%A0%84%ED%95%98%EA%B8%B0\">괄호 회전하기</a></p>\n<ul>\n<li><a href=\"#%EB%AC%B8%EC%A0%9C-%ED%92%80%EC%9D%B4\">문제 풀이</a></li>\n</ul>\n</li>\n<li>\n<p><a href=\"#%EC%BD%94%EB%93%9C\">코드</a></p>\n</li>\n</ul>"},"relatedPosts":{"totalCount":24,"edges":[{"node":{"id":"de5c1727-dfbc-5afb-9e74-15eb7dd6734a","excerpt":"파일명 정렬 문제 링크 문제 풀이 각 파일명이 문자열로 주어지며, 주어진 조건으로 파일명을 정렬하는 문제이다. 풀이 순서는 다음과 같다. Array.sort함수에 조건을 만족하는 익명함수(customSort(a, b…","frontmatter":{"title":"알고리즘 문제 풀이 - 파일명 정렬","date":"2021-04-23T00:00:00.000Z"},"fields":{"readingTime":{"text":"1 min read"},"slug":"/posts/algorithm/sort_file