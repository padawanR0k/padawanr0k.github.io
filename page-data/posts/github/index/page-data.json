ype":"text","value":"\n"}]},{"type":"text","value":"\n"}]},{"type":"text","value":"\n"}]},{"type":"text","value":"\n"},{"type":"element","tagName":"h3","properties":{"id":"기능-2---자동화","style":"position:relative;"},"children":[{"type":"element","tagName":"a","properties":{"href":"#%EA%B8%B0%EB%8A%A5-2---%EC%9E%90%EB%8F%99%ED%99%94","ariaLabel":"기능 2   자동화 permalink","className":["anchor","before"]},"children":[{"type":"element","tagName":"svg","properties":{"ariaHidden":"true","focusable":"false","height":"16","version":"1.1","viewBox":"0 0 16 16","width":"16"},"children":[{"type":"element","tagName":"path","properties":{"fillRule":"evenodd","d":"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z"},"children":[]}]}]},{"type":"text","value":"기능 2 - 자동화"}]},{"type":"text","value":"\n"},{"type":"element","tagName":"hr","properties":{},"children":[]},{"type":"text","value":"\n"},{"type":"element","tagName":"p","properties":{},"children":[{"type":"text","value":"주기적으로 특정작업을 실행하는 자동화는 소프트웨어 유틸리티인 cron을 사용한다. 예로 서비스를 운영하기위해 재결제문자 같은걸 발송할 때 사용한다. 내가 하려는 것도 주기적이기 때문에 cron을 사용했다. 마침 예전에 기술블로그에서 "},{"type":"element","tagName":"a","properties":{"href":"https://ryanking13.github.io/2019/12/29/twitter-bot-without-server.html"},"children":[{"type":"text","value":"github action으로 서버상태 체크하는 봇 만들기"}]},{"type":"text","value":" 라는글을 봤던적이 있었고, 비슷한 개념의 활용이라 생각되서 github action을 사용하게됬다."}]},{"type":"text","value":"\n"},{"type":"element","tagName":"p","properties":{},"children":[{"type":"element","tagName":"a","properties":{"href":"https://github.com/features/actions"},"children":[{"type":"text","value":"github action"}]},{"type":"text","value":"은 소프트웨어의 워크플로우를 쉽게 자동화 해준다. 프로젝트 빌드, 테스트, 배포 등을 github 플랫폼 안에서 해결 할 수 있다.  (repository에 git push했을 때, test를 돌리고 이상없으면 deploy하는  jenkins가 하던 기능이 github 플랫폼내부에 있는것이다. 이것말고도 다양한걸 할 수 있다.)"}]},{"type":"text","value":"\n"},{"type":"element","tagName":"p","properties":{},"children":[{"type":"text","value":"github action는 push같은 repository의 변화를 감지해서 코드의 테스트나 배포를 담당하는 스크립트를 작동시킬 수 도 있지만, cron을 스케쥴링할 수 도 있다."}]},{"type":"text","value":"\n"},{"type":"element","tagName":"ul","properties":{},"children":[{"type":"text","value":"\n"},{"type":"element","tagName":"li","properties":{},"children":[{"type":"text","value":"플로우\n"},{"type":"element","tagName":"ul","properties":{},"children":[{"type":"text","value":"\n"},{"type":"element","tagName":"li","properties":{},"children":[{"type":"text","value":"\n"},{"type":"element","tagName":"p","properties":{},"children":[{"type":"text","value":"기능1에서 작성한 코드를 repository에 push한다"}]},{"type":"text","value":"\n"}]},{"type":"text","value":"\n"},{"type":"element","tagName":"li","properties":{},"children":[{"type":"text","value":"\n"},{"type":"element","tagName":"p","properties":{},"children":[{"type":"text","value":"Actions탭에서 새로운 워크플로우를 만들고 yml파일을 수정한다."}]},{"type":"text","value":"\n"},{"type":"element","tagName":"deckgo-highlight-code","properties":{"yaml":"","theme":"one-dark","highlight-lines":""},"children":[{"type":"text","value":"\n          "},{"type":"element","tagName":"code","properties":{"slot":"code"},"children":[{"type":"text","value":"\nname: lotto645_crawler\n\non:\n  schedule:\n      - cron: '55 11 * * *'\n  workflow_dispatch:\n\njobs:\n  cron:\n    runs-on: ubuntu-latest\n\n    steps:\n      - uses: actions/checkout@v2\n      - name: set up python\n        uses: actions/setup-python@v2\n        with:\n          python-version: '3.7.6'\n          architecture: 'x64'\n      - run: |\n          pip install -r scraping/requirements.txt\n          python scraping/main.py\n        env:\n          PAT: ${{ secrets.PAT }}"}]},{"type":"text","value":"\n        "}]},{"type":"text","value":"\n"},{"type":"el